{
    "manifest_version": 3,
    "name": "MSG_extName",
    "short_name": "MSG_extShortName",
    "version": "1.0.0",
    "description": "MSG_extDesc",
    "default_locale": "en",
    "author": "delong",
    "icons": {
        "16": "icons/icon-16.png",
        "48": "icons/icon-48.png",
        "128": "icons/icon-128.png"
    },
    "content_scripts": [
        {
            "matches": ["*://*.kobo.com/*"],
            "js": ["content.js"],
            "run_at": "document_idle"
        }
    ]
}